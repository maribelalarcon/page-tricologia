---
const { title, description, href } = Astro.props;
---

{
  href ? (
    <a
      href={href}
      class="block p-6 bg-white rounded-xl shadow hover:shadow-lg hover:-translate-y-1 transition"
    >
      <h3 class="text-xl text-[#0B2545] font-semibold mb-2">{title}</h3>
      <p class="text-gray-600">{description}</p>
    </a>
  ) : (
    <div class="p-6 bg-white rounded-xl shadow hover:shadow-lg transition">
      <h3 class="text-xl text-[#0B2545] font-semibold mb-2">{title}</h3>
      <p class="text-gray-600">{description}</p>
    </div>
  )
}
