---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="px-6 py-20 max-w-7xl mx-auto">
    <!-- Centered Title -->
    <h2
      class="text-[#0B2545] text-3xl md:text-4xl font-extrabold text-center uppercase mb-12"
    >
      Contact Us
    </h2>

    <!-- Main Container -->
    <div class="flex flex-col md:flex-row items-start gap-12">
      <!-- Text -->
      <div
        class="w-full md:w-1/2 text-center md:text-left flex flex-col justify-center"
      >
        <p class="text-gray-700 text-2xl leading-7 mb-6">
          ¿Tienes alguna pregunta? Estoy aquí para ayudarte.
        </p>
        <p class="text-gray-700 text-2xl leading-7 mb-6">
          Si necesitas más información, tienes alguna duda sobre los
          tratamientos o quieres realizar una consulta, puedes enviarme un
          mensaje a través de este formulario.
        </p>
        <p class="text-gray-700 text-2xl leading-7">
          Completa tus datos y escribe tu consulta. Te responderé lo antes
          posible.
        </p>
      </div>

      <!-- Form -->
      <div class="w-full md:w-1/2 bg-gray-50 rounded-2xl">
        <form>
          <!-- Two-column grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Nombre -->
            <div class="flex flex-col">
              <label for="nombre" class="font-semibold text-[#0B2545] mb-2">
                Nombre
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder="Tu nombre"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
                required
              />
            </div>

            <!-- Apellidos -->
            <div class="flex flex-col">
              <label for="apellido" class="font-semibold text-[#0B2545] mb-2">
                Apellidos
              </label>
              <input
                type="text"
                id="apellido"
                name="apellido"
                placeholder="Tus apellidos"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
                required
              />
            </div>

            <!-- Correo -->
            <div class="flex flex-col">
              <label for="correo" class="font-semibold text-[#0B2545] mb-2">
                Correo electrónico
              </label>
              <input
                type="email"
                id="correo"
                name="correo"
                placeholder="tucorreo@ejemplo.com"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
                required
              />
            </div>

            <!-- Teléfono -->
            <div class="flex flex-col">
              <label for="telefono" class="font-semibold text-[#0B2545] mb-2">
                Teléfono
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="+52 55 1234 5678"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
              />
            </div>
          </div>

          <!-- Mensaje -->
          <div class="flex flex-col mt-6">
            <label for="mensaje" class="font-semibold text-[#0B2545] mb-2">
              Mensaje
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              placeholder="Escribe aquí tu consulta..."
              class="border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#F9C74F] resize-none"
              required></textarea>
          </div>

          <!-- Button -->
          <div class="text-center md:text-right mt-4">
            <button
              type="submit"
              class="bg-[#F9C74F] text-[#0B2545] hover:bg-[#f1b500] font-bold px-14 py-3 rounded-full cursor-pointer transition"
            >
              Enviar
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>
